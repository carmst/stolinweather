{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "cleanUrls": true,
  "functions": {
    "api/dashboard.js": {
      "includeFiles": "{config/tracked_markets.json,config/watchlist.json,output/kalshi/latest_markets.json,output/models/latest_scored_markets.json,output/history/latest_noaa_history.json,output/preliminary/latest_preliminary_daily_highs.json}"
    },
    "api/history.js": {
      "includeFiles": "{config/tracked_markets.json,output/history/latest_noaa_history.json,output/preliminary/latest_preliminary_daily_highs.json,output/models/latest_scored_markets.json}"
    },
    "api/watchlist.js": {
      "includeFiles": "{config/tracked_markets.json,config/watchlist.json,output/kalshi/latest_markets.json,output/models/latest_scored_markets.json}"
    },
    "api/market-detail.js": {
      "includeFiles": "{config/tracked_markets.json,config/watchlist.json,output/kalshi/latest_markets.json,output/models/latest_scored_markets.json,output/history/latest_noaa_history.json,output/preliminary/latest_preliminary_daily_highs.json}"
    }
  }
}
