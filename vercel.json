{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "cleanUrls": true,
  "functions": {
    "api/dashboard.js": {
      "includeFiles": "{config/*.json,output/kalshi/latest_markets.json,output/models/latest_scored_markets.json,output/history/latest_noaa_history.json,output/preliminary/latest_preliminary_daily_highs.json,output/weather/latest_forecasts*.json}"
    },
    "api/history.js": {
      "includeFiles": "{config/*.json,output/kalshi/latest_markets.json,output/models/latest_scored_markets.json,output/history/latest_noaa_history.json,output/preliminary/latest_preliminary_daily_highs.json,output/weather/latest_forecasts*.json}"
    },
    "api/watchlist.js": {
      "includeFiles": "{config/*.json,output/kalshi/latest_markets.json,output/models/latest_scored_markets.json,output/history/latest_noaa_history.json,output/preliminary/latest_preliminary_daily_highs.json,output/weather/latest_forecasts*.json}"
    },
    "api/market-detail.js": {
      "includeFiles": "{config/*.json,output/kalshi/latest_markets.json,output/models/latest_scored_markets.json,output/history/latest_noaa_history.json,output/preliminary/latest_preliminary_daily_highs.json,output/weather/latest_forecasts*.json}"
    }
  }
}
