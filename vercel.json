{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "cleanUrls": true,
  "functions": {
    "api/django.py": {
      "includeFiles": "{django_app/**,deploy_data/**,config/*.json}",
      "maxDuration": 30
    },
    "api/dashboard.js": {
      "includeFiles": "{config/*.json,deploy_data/**}"
    },
    "api/history.js": {
      "includeFiles": "{config/*.json,deploy_data/**}"
    },
    "api/watchlist.js": {
      "includeFiles": "{config/*.json,deploy_data/**}"
    },
    "api/market-detail.js": {
      "includeFiles": "{config/*.json,deploy_data/**}"
    }
  },
  "rewrites": [
    {
      "source": "/static/:path*",
      "destination": "/django_app/static/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/api/django"
    }
  ]
}
